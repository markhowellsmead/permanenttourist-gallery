RewriteEngine On

# Don't cache the API responses
SetEnvIf Request_URI "^/api(?:/.*)?$" NO_CACHE=1

# 7-day caching for frontend assets (exclude API via `NO_CACHE` env)
<IfModule mod_expires.c>
	ExpiresActive On
	ExpiresDefault "access plus 7 days"
	ExpiresByType text/css "access plus 7 days"
	ExpiresByType text/javascript "access plus 7 days"
	ExpiresByType application/javascript "access plus 7 days"
	ExpiresByType application/x-javascript "access plus 7 days"
	ExpiresByType image/jpeg "access plus 7 days"
	ExpiresByType image/png "access plus 7 days"
	ExpiresByType image/gif "access plus 7 days"
	ExpiresByType image/webp "access plus 7 days"
	ExpiresByType image/avif "access plus 7 days"
	ExpiresByType image/svg+xml "access plus 7 days"
	ExpiresByType text/html "access plus 7 days"
</IfModule>

<IfModule mod_headers.c>
	# Caching for static assets only
	<FilesMatch "\.(css|js|jpg|jpeg|png|gif|webp|avif|svg)$">
		# Keep a 7-day cache window, but allow hard reload / Disable cache to revalidate.
		Header set Cache-Control "public, max-age=604800, no-transform" env=!NO_CACHE
	</FilesMatch>
	<FilesMatch "\.(html|htm)$">
		Header set Cache-Control "public, max-age=604800" env=!NO_CACHE
	</FilesMatch>

	# Explicitly disable caching for API endpoints
	Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0" env=NO_CACHE
	Header set Pragma "no-cache" env=NO_CACHE
	Header unset Expires env=NO_CACHE
</IfModule>

# Redirect non-image requests in /media to the site root
RewriteRule ^media/?$ / [R=302,L]

RewriteCond %{REQUEST_URI} ^/media/ [NC]
RewriteCond %{REQUEST_URI} !\.(?:jpe?g|png|gif|webp|avif|svg)$ [NC]
RewriteRule ^media/ / [R=302,L]

# Disallow direct access to helper include files
RewriteRule ^functions\.php$ - [F,L,NC]
RewriteRule ^src/ - [F,L,NC]

# Route API requests (including readable filter URLs) to api.php
RewriteRule ^api(?:/.*)?$ api.php [L,QSA]

# Serve existing files and directories directly
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Allow only these application routes
RewriteRule ^$ index.php [L,QSA]
RewriteRule ^build/?$ index.php [L,QSA]
RewriteRule ^update/?$ index.php [L,QSA]
RewriteRule ^sitemap/?$ index.php [L,QSA]
RewriteRule ^photo/[^/]+/?$ index.php [L,QSA]
RewriteRule ^fetch-from-email/?$ fetch-from-email.php [L,QSA]

# Everything else should render the custom 404 page
RewriteRule ^ 404.php [L]
