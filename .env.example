# Example environment variables for gallery application

# Update endpoint authentication token
# Set this to a secure random string
# Example: openssl rand -hex 32
UPDATE_TOKEN=change_this_secret_token

# GitHub Personal Access Token for update endpoint
# Required if the git remote uses SSH and the web server user doesn't have SSH keys
# Create at: https://github.com/settings/tokens (needs 'repo' scope)
GITHUB_TOKEN=

# Base URL used when generating sitemap.xml during build
# Example: https://gallery.example.com
SITE_URL=https://gallery.example.com

### IMAP mailbox configuration (used by /fetch-from-email endpoint)
# Hostname or IP of the IMAP server
IMAP_HOST=
# Port number (defaults to 993 for ssl, 143 otherwise)
IMAP_PORT=993
# Username for the IMAP account
IMAP_USER=
# Password for the IMAP account
IMAP_PASS=
# Mailbox/folder to read (defaults to INBOX)
IMAP_MAILBOX=INBOX
# Encryption: "ssl" or "tls" (defaults to ssl)
IMAP_ENCRYPTION=ssl
